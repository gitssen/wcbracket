datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String
  totalPoints  Int          @default(0)
  hasSubmitted Boolean      @default(false)
  predictions  Prediction[]
}

model Match {
  id               Int          @id
  round            String // "ROUND_OF_32", "ROUND_OF_16", "QUARTER_FINALS", "SEMI_FINALS", "FINALS"
  homeTeam         String
  homeCode         String
  awayTeam         String
  awayCode         String
  homeScore        Int?
  awayScore        Int?
  wentToPenalties  Boolean      @default(false)
  actualWinner     String?
  actualWinnerCode String?
  isCompleted      Boolean      @default(false)
  nextMatchId      Int?
  isHomeInNext     Boolean
  predictions      Prediction[]
}

model Prediction {
  id                  String  @id @default(cuid())
  userId              String
  matchId             Int
  predictedWinner     String
  predictedWinnerCode String
  predictedHomeScore  Int
  predictedAwayScore  Int
  predictPenalties    Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}
